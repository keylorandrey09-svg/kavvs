<script>
/* ═══════════════════════════
   STATE
═══════════════════════════ */
const S = {
  phrase:'', firma:'',
  style:'dark', format:'post',
  accent:'#c4a35a', font:'playfair',
  bgImage:null, imgOn:false,
  opacity:70, blur:0, dim:50,
};

const FORMATS = {
  post:     {w:1080,h:1080, label:'Post Instagram',    size:'1080 × 1080 px', use:'Feed principal · Cuadrado'},
  story:    {w:1080,h:1920, label:'Historia',          size:'1080 × 1920 px', use:'IG Stories · TikTok · Reels'},
  portrait: {w:1080,h:1350, label:'Retrato IG',        size:'1080 × 1350 px', use:'Feed Instagram · Vertical'},
  landscape:{w:1200,h:628,  label:'Paisaje',           size:'1200 × 628 px',  use:'Twitter · LinkedIn · Web'},
  pinterest:{w:1000,h:1500, label:'Pinterest',         size:'1000 × 1500 px', use:'Pin · Vertical largo'},
  ytthumb:  {w:1280,h:720,  label:'YouTube Thumb',     size:'1280 × 720 px',  use:'Miniatura · 16:9'},
};

const STYLES_DEF = {
  dark:      {bg:'#080808',bg2:'#0c0c0c',text:'#f0ece4',muted:'rgba(240,236,228,.48)',vignette:true,  layout:'center', previewBg:'#080808',previewText:'#f0ece4'},
  minimal:   {bg:'#f7f5f1',bg2:'#eeebe5',text:'#111',   muted:'rgba(17,17,17,.45)',   vignette:false, layout:'center', previewBg:'#f7f5f1',previewText:'#111'},
  editorial: {bg:'#0a0a0a',bg2:'#0f0f0f',text:'#ede8df',muted:'rgba(237,232,223,.42)',vignette:false, layout:'left',   previewBg:'#0a0a0a',previewText:'#ede8df'},
  premium:   {bg:'#0b0904',bg2:'#100d07',text:'#f5edd8',muted:'rgba(245,237,216,.45)',vignette:true,  layout:'center', previewBg:'#0b0904',previewText:'#f5edd8'},
  neon:      {bg:'#030308',bg2:'#050514',text:'#e8f0ff',muted:'rgba(200,220,255,.5)', vignette:true,  layout:'center', previewBg:'#030308',previewText:'#e8f0ff'},
  aesthetic: {bg:'#f4efe9',bg2:'#ece6de',text:'#3d3530',muted:'rgba(61,53,48,.42)',   vignette:false, layout:'center', previewBg:'#f4efe9',previewText:'#3d3530'},
  bold:      {bg:'#111',   bg2:'#0a0a0a',text:'#ffffff', muted:'rgba(255,255,255,.5)',vignette:false, layout:'center', previewBg:'#111',   previewText:'#fff'},
  nature:    {bg:'#0d1208',bg2:'#111a0a',text:'#e8f0d8',muted:'rgba(200,220,160,.48)',vignette:true,  layout:'center', previewBg:'#0d1208',previewText:'#e8f0d8'},
};

const FONTS_DEF = {
  playfair:  {css:"'Playfair Display',serif",  italic:true,  weight:'400'},
  syne:      {css:"'Syne',sans-serif",          italic:false, weight:'700'},
  bebas:     {css:"'Bebas Neue',sans-serif",    italic:false, weight:'400'},
  cormorant: {css:"'Cormorant Garamond',serif", italic:true,  weight:'300'},
  dmsans:    {css:"'DM Serif Display',serif",   italic:false, weight:'400'},
};

/* ═══════════════════════════
   CURSOR (desktop)
═══════════════════════════ */
const cur=document.getElementById('cur'), curR=document.getElementById('curR');
let mx=200,my=200,rx=200,ry=200;
if(window.innerWidth>900){
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
  (function a(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;curR.style.left=rx+'px';curR.style.top=ry+'px';requestAnimationFrame(a)})();
}

/* ═══════════════════════════
   STYLE CARDS BUILD
═══════════════════════════ */
function buildStyles(){
  const wrap = document.getElementById('stylesScroll');
  wrap.innerHTML = Object.entries(STYLES_DEF).map(([key,s])=>`
    <div class="style-card${key===S.style?' on':''}" onclick="setStyle('${key}',this)">
      <div class="style-prev" style="background:${s.previewBg}">
        <div class="style-prev-text" style="color:${s.previewText};font-family:${FONTS_DEF[S.font].css};font-style:${FONTS_DEF[S.font].italic?'italic':'normal'}">${key==='editorial'?'▌ ':''}"Frase"</div>
      </div>
      <div class="style-name">${key.charAt(0).toUpperCase()+key.slice(1)}</div>
    </div>
  `).join('');
}

/* ═══════════════════════════
   CONTROLS
═══════════════════════════ */
function onPhrase(el){
  S.phrase=el.value;
  document.getElementById('charCount').textContent=el.value.length;
  renderCanvas();
}

function setStyle(s,el){
  S.style=s;
  document.querySelectorAll('.style-card').forEach(c=>c.classList.remove('on'));
  if(el)el.classList.add('on');
  renderCanvas();
}

function setFmt(f,el){
  S.format=f;
  document.querySelectorAll('.fmt-chip').forEach(c=>c.classList.remove('on'));
  if(el)el.classList.add('on');
  // Update right panel labels
  const fd=FORMATS[f];
  const ll=document.getElementById('fmtActiveLabel');
  const ls=document.getElementById('fmtActiveSize');
  const lu=document.getElementById('fmtActiveUse');
  if(ll)ll.textContent=fd.label;
  if(ls)ls.textContent=fd.size;
  if(lu)lu.textContent=fd.use;
  renderCanvas();
}

function setFont(f,el){
  S.font=f;
  document.querySelectorAll('.font-btn').forEach(b=>b.classList.remove('on'));
  if(el)el.classList.add('on');
  buildStyles();
  renderCanvas();
}

function setAcc(c,el){
  S.accent=c;
  document.querySelectorAll('.csw').forEach(s=>s.classList.remove('on'));
  if(el)el.classList.add('on');
  renderCanvas();
}

function onSlider(type,el){
  const v=parseInt(el.value);
  if(type==='opacity'){S.opacity=v;document.getElementById('opacityVal').textContent=v+'%'}
  if(type==='blur'){S.blur=v;document.getElementById('blurVal').textContent=v+'px'}
  if(type==='dim'){S.dim=v;document.getElementById('dimVal').textContent=v+'%'}
  renderCanvas();
}

/* ═══════════════════════════
   IMAGE
═══════════════════════════ */
function toggleImg(){
  S.imgOn=document.getElementById('imgToggle').checked;
  renderCanvas();
}

function handleImg(input){
  if(!input.files||!input.files[0])return;
  const reader=new FileReader();
  reader.onload=e=>{
    const img=new Image();
    img.onload=()=>{
      S.bgImage=img;
      S.imgOn=true;
      document.getElementById('imgToggle').checked=true;
      const thumb=document.getElementById('imgThumb');
      thumb.src=e.target.result;
      thumb.style.display='block';
      document.getElementById('imgHint').style.display='none';
      document.getElementById('imgClearBtn').style.display='block';
      document.getElementById('imgControls').style.display='flex';
      renderCanvas();
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(input.files[0]);
}

function clearImg(){
  S.bgImage=null;S.imgOn=false;
  document.getElementById('imgToggle').checked=false;
  document.getElementById('imgThumb').style.display='none';
  document.getElementById('imgHint').style.display='flex';
  document.getElementById('imgClearBtn').style.display='none';
  document.getElementById('imgControls').style.display='none';
  document.getElementById('imgFile').value='';
  renderCanvas();
}

/* ═══════════════════════════
   RENDER CANVAS
═══════════════════════════ */
function renderCanvas(){
  S.phrase=document.getElementById('phraseInput').value;
  S.firma=document.getElementById('firmaInput').value;

  const fmt=FORMATS[S.format];
  const sty=STYLES_DEF[S.style];
  const fnt=FONTS_DEF[S.font];
  const W=fmt.w, H=fmt.h;

  const canvas=document.getElementById('mainCanvas');
  const ctx=canvas.getContext('2d');
  canvas.width=W; canvas.height=H;

  // Scale display
  const area=document.getElementById('canvasArea')||document.querySelector('.canvas-sec');
  const areaW=Math.min(window.innerWidth-40, window.innerWidth>900?480:window.innerWidth-40);
  const areaH=Math.min(window.innerHeight*.65, 560);
  const scaleW=areaW/W, scaleH=areaH/H;
  const ds=Math.min(scaleW,scaleH);
  canvas.style.width=(W*ds)+'px';
  canvas.style.height=(H*ds)+'px';

  // ── BG ──
  const grad=ctx.createLinearGradient(0,0,W*.2,H);
  grad.addColorStop(0,sty.bg); grad.addColorStop(1,sty.bg2);
  ctx.fillStyle=grad; ctx.fillRect(0,0,W,H);

  // ── BACKGROUND IMAGE ──
  if(S.imgOn && S.bgImage){
    ctx.save();
    // Blur via offscreen
    if(S.blur>0){
      const offscreen=document.createElement('canvas');
      offscreen.width=W;offscreen.height=H;
      const octx=offscreen.getContext('2d');
      octx.filter=`blur(${S.blur*2}px)`;
      const iR=S.bgImage.width/S.bgImage.height;
      const cR=W/H;
      let sx=0,sy=0,sw=S.bgImage.width,sh=S.bgImage.height;
      if(iR>cR){sw=S.bgImage.height*cR;sx=(S.bgImage.width-sw)/2}
      else{sh=S.bgImage.width/cR;sy=(S.bgImage.height-sh)/2}
      octx.drawImage(S.bgImage,sx,sy,sw,sh,0,0,W,H);
      ctx.globalAlpha=S.opacity/100;
      ctx.drawImage(offscreen,0,0,W,H);
    } else {
      const iR=S.bgImage.width/S.bgImage.height;
      const cR=W/H;
      let sx=0,sy=0,sw=S.bgImage.width,sh=S.bgImage.height;
      if(iR>cR){sw=S.bgImage.height*cR;sx=(S.bgImage.width-sw)/2}
      else{sh=S.bgImage.width/cR;sy=(S.bgImage.height-sh)/2}
      ctx.globalAlpha=S.opacity/100;
      ctx.drawImage(S.bgImage,sx,sy,sw,sh,0,0,W,H);
    }
    ctx.restore();
    // Dim overlay
    if(S.dim>0){
      ctx.fillStyle=`rgba(0,0,0,${S.dim/100})`;
      ctx.fillRect(0,0,W,H);
    }
  }

  // ── STYLE EFFECTS ──
  styleEffects(ctx,W,H,sty);

  // ── GRAIN ──
  if(sty.vignette) drawVignette(ctx,W,H,sty.bg);

  // ── TEXT ──
  const phrase=S.phrase||'Tu frase aquí.';
  const firma=S.firma;
  const isLeft=sty.layout==='left';
  const textX=isLeft?W*.1:W/2;
  const align=isLeft?'left':'center';

  ctx.textAlign=align; ctx.textBaseline='alphabetic';

  const baseSize=Math.min(W,H)*.095;
  const lineH=baseSize*1.2;

  const fi=fnt.italic?'italic ':'';
  ctx.font=`${fi}${fnt.weight} ${baseSize}px ${fnt.css}`;
  const maxW2=W*(isLeft?.76:.8);
  const lines=wrapText(ctx,phrase,maxW2);

  const totalH=lines.length*lineH;
  let y=H/2-totalH/2+baseSize;
  if(isLeft)y=H*.32+baseSize;

  // text shadow
  ctx.shadowColor='rgba(0,0,0,0.5)';
  ctx.shadowBlur=baseSize*.4;

  lines.forEach((line,i)=>{
    ctx.fillStyle=sty.text;
    ctx.font=`${fi}${fnt.weight} ${baseSize}px ${fnt.css}`;
    ctx.fillText(line,textX,y+i*lineH);
  });
  ctx.shadowBlur=0;

  y+=lines.length*lineH+baseSize*.3;

  // Accent line
  if(S.style!=='bold'){
    const lw=isLeft?W*.12:Math.min(W*.2,180);
    const lx=isLeft?textX:W/2-lw/2;
    ctx.fillStyle=S.accent;
    ctx.fillRect(lx,y,lw,Math.max(2,H*.003));
    y+=H*.04;
  } else {
    // Bold: accent bar at bottom
    ctx.fillStyle=S.accent;
    ctx.fillRect(0,H*.9,W,H*.1);
    y+=H*.03;
  }

  // Firma
  if(firma){
    const fSize=baseSize*.28;
    ctx.font=`500 ${fSize}px 'Syne',sans-serif`;
    ctx.fillStyle=S.accent;
    ctx.textAlign='center';
    ctx.shadowColor='rgba(0,0,0,0.4)';
    ctx.shadowBlur=fSize*.5;
    ctx.fillText(firma,W/2,H-H*.055);
    ctx.shadowBlur=0;
  }

  // KAVSS mark
  ctx.font=`500 ${Math.max(20,H*.018)}px 'Syne',sans-serif`;
  ctx.fillStyle='rgba(255,255,255,0.07)';
  ctx.textAlign='right';
  ctx.fillText('KAVSS',W-W*.04,H-H*.022);
}

/* ── HELPERS ── */
function wrapText(ctx,text,maxW){
  const words=text.split(' ');
  const lines=[];let line='';
  words.forEach(w=>{
    const t=line?line+' '+w:w;
    if(ctx.measureText(t).width>maxW&&line){lines.push(line);line=w}
    else line=t;
  });
  if(line)lines.push(line);
  return lines.slice(0,6);
}

function drawVignette(ctx,W,H,bg){
  const g=ctx.createRadialGradient(W/2,H/2,H*.1,W/2,H/2,H*.85);
  g.addColorStop(0,'transparent');
  g.addColorStop(1,bg+'cc');
  ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
}

function styleEffects(ctx,W,H,sty){
  if(S.style==='editorial'){
    ctx.fillStyle=S.accent;
    ctx.fillRect(0,0,Math.max(12,W*.035),H);
    ctx.fillStyle='rgba(255,255,255,0.025)';
    ctx.fillRect(W*.048,0,Math.max(2,W*.003),H);
  }
  if(S.style==='premium'){
    const g=ctx.createRadialGradient(W/2,H*.4,0,W/2,H*.4,W*.6);
    g.addColorStop(0,S.accent+'1a');g.addColorStop(1,'transparent');
    ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
    drawCorners(ctx,W,H);
  }
  if(S.style==='neon'){
    const g=ctx.createRadialGradient(W*.3,H*.3,0,W*.3,H*.3,W*.5);
    g.addColorStop(0,S.accent+'2a');g.addColorStop(1,'transparent');
    ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(255,255,255,.015)';ctx.lineWidth=1;
    for(let i=0;i<H;i+=6){ctx.beginPath();ctx.moveTo(0,i);ctx.lineTo(W,i);ctx.stroke()}
  }
  if(S.style==='aesthetic'){
    const g=ctx.createRadialGradient(W*.75,H*.25,0,W*.75,H*.25,W*.55);
    g.addColorStop(0,S.accent+'28');g.addColorStop(1,'transparent');
    ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
    ctx.strokeStyle=S.accent+'2a';ctx.lineWidth=Math.max(2,W*.005);
    ctx.beginPath();ctx.arc(W*.5,H*.5,Math.min(W,H)*.42,0,Math.PI*2);ctx.stroke();
  }
  if(S.style==='dark'){
    ctx.strokeStyle='rgba(255,255,255,0.022)';ctx.lineWidth=1;
    [H*.2,H*.8].forEach(y=>{ctx.beginPath();ctx.moveTo(W*.04,y);ctx.lineTo(W*.96,y);ctx.stroke()});
  }
  if(S.style==='nature'){
    const g=ctx.createRadialGradient(W/2,H*.5,0,W/2,H*.5,W*.7);
    g.addColorStop(0,S.accent+'18');g.addColorStop(1,'transparent');
    ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
  }
}

function drawCorners(ctx,W,H){
  ctx.strokeStyle=S.accent+'3a';
  ctx.lineWidth=Math.max(2,W*.003);
  const m=W*.055,s=W*.08;
  [[m,m],[W-m,m],[m,H-m],[W-m,H-m]].forEach(([x,y],i)=>{
    const sx=i%2===0?s:-s, sy=i<2?s:-s;
    ctx.beginPath();ctx.moveTo(x+sx,y);ctx.lineTo(x,y);ctx.lineTo(x,y+sy);ctx.stroke();
  });
}

